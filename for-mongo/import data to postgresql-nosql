CREATE EXTENSION mysql_fdw;

DROP SERVER mongo_mysql CASCADE;

CREATE SERVER mongo_mysql
FOREIGN DATA WRAPPER mysql_fdw
OPTIONS (
    host 'mongo-bi',
    port '3307',
    use_remote_estimate 'false',
    fetch_size '100'
);

CREATE USER MAPPING FOR postgres
SERVER mongo_mysql
OPTIONS (
    username 'system',
    password 'mongo'
);

CREATE SCHEMA mongo_data;

IMPORT FOREIGN SCHEMA movies_db
FROM SERVER mongo_mysql
INTO mongo_data;

SELECT column_name, data_type
FROM information_schema.columns
WHERE table_schema = 'mongo_data'
AND table_name = 'movies';